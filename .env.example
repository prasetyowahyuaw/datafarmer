PROJECT_ID = your-gcp-project-id
DATASET_ID = your-gcp-dataset-id
GDRIVE_FOLDER_ID = your-gdrive-folder-name
VERTEX_CORPUS_ID = your-vertex-corpus-id

# GenAI Gateway passthrough credentials (JSON string).
# Expected shape: {"vertex_ai_passthrough": {<google.genai HttpOptions fields, e.g. headers/base_url>}}
GENAI_CREDENTIALS = '{"vertex_ai_passthrough": {"headers": {"Authorization": "Bearer your-token"}}}'